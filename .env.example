# Copy this file to .env and fill in real values before running the server.
# Never commit the actual .env file to git — it holds secrets.

# Long, random string used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# How long a login session stays valid before the user has to sign in again.
JWT_EXPIRES_IN=7d

# Port the server listens on. Most hosting platforms (Railway, Render, etc.)
# set this automatically — you usually don't need to change it.
PORT=4000

# Comma-separated list of front-end URLs allowed to call this API.
# Add your deployed dashboard's URL here once you have one.
ALLOWED_ORIGINS=http://localhost:3000
